# ── Camille Core — Variables d'environnement ──────────────────────────────────
# Copiez ce fichier en .env et remplissez les valeurs

# ── Application ────────────────────────────────────────────────────────────────
# Port d'écoute
# Local: 3000
# Render: 10000 (automatique)
PORT=3000

# Node Environment
NODE_ENV=development

# Clé API — protège tous les endpoints /api/*
# Utilisée dans n8n comme header X-Api-Key
# ⚠️  CHANGEZ CETTE VALEUR avant production!
API_KEY=your-secure-api-key-here

# ── Storage ────────────────────────────────────────────────────────────────────
# Répertoire des sessions (auth Baileys, analytics)
# Local: ./sessions
# Render: /var/data/sessions (persistent disk)
SESSIONS_DIR=./sessions

# ── N8N Webhooks ───────────────────────────────────────────────────────────────
# Webhook global — reçoit tous les messages WhatsApp entrants
N8N_WEBHOOK_URL=https://your-n8n.com/webhook/camille

# Webhooks par session (optionnel — surcharge N8N_WEBHOOK_URL)
# N8N_WEBHOOK_DEFAULT=https://your-n8n.com/webhook/default
# N8N_WEBHOOK_BOT1=https://your-n8n.com/webhook/bot1

# ── Monitoring ─────────────────────────────────────────────────────────────────
# Niveau de log Baileys (fatal, error, warn, info, debug)
BAILEYS_LOG_LEVEL=fatal

# Intervalle watchdog (ms) — surveille les connexions "zombie"
WATCHDOG_INTERVAL_MS=60000

# Délai initial avant reconnexion (ms)
RECONNECT_BASE_MS=5000

# Nombre max de tentatives de reconnexion
MAX_RECONNECT_TRIES=10

# Timeout d'initialisation (ms) — bloqué au-delà = recréation
INIT_TIMEOUT_MS=180000

# ── Limites ────────────────────────────────────────────────────────────────────
# Nombre max de sessions simultanées
MAX_SESSIONS=5

# Rétention analytics (jours)
ANALYTICS_RETENTION_DAYS=90

# ── Zombie Detection ───────────────────────────────────────────────────────────
# Sonde après silence (ms)
ZOMBIE_PROBE_AFTER_MS=300000

# Reconnexion forcée après silence (ms)
ZOMBIE_HARD_MS=1800000
