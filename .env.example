# ── Camille Core — Variables d'environnement ──────────────────────────────────
# Copiez ce fichier en .env et remplissez les valeurs

# Port d'écoute (défaut: 3000)
PORT=3000

# Clé API — protège tous les endpoints /api/*
# Utilisée dans n8n comme header X-Api-Key
API_KEY=camille-core-secret-changez-moi

# Webhook n8n global — reçoit tous les messages WhatsApp entrants
# Doit correspondre au chemin du webhook WAHA dans votre workflow n8n
N8N_WEBHOOK_URL=https://n8n.vps.buyticle.com/webhook/whatsapp-waha

# Webhooks par session (optionnel — surcharge N8N_WEBHOOK_URL pour cette session)
# Remplacez DEFAULT par le nom de votre session en MAJUSCULES
N8N_WEBHOOK_DEFAULT=https://n8n.vps.buyticle.com/webhook/whatsapp-waha
# N8N_WEBHOOK_SESSION2=https://n8n.vps.buyticle.com/webhook/session2
